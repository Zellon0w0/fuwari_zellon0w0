---
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import type { GetStaticPaths } from "astro";
import { Icon } from "astro-icon/components";
import PostPage from "../components/PostPage.astro";
import Profile from "../components/widget/Profile.astro";
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { getSortedPosts, getSortedThoughts } from "../utils/content-utils";
import { url } from "../utils/url-utils";

const LATEST_POSTS_COUNT = 3;

export const getStaticPaths = (async ({ paginate }) => {
	const allBlogPosts = await getSortedPosts();
	return paginate(allBlogPosts, { pageSize: 1000 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const thoughts = await getSortedThoughts();
const latestThoughts = [...thoughts]
	.sort((a, b) => b.data.published.getTime() - a.data.published.getTime())
	.slice(0, 1);

const latestPostsPage = {
	...page,
	data: page.data.slice(0, LATEST_POSTS_COUNT),
};

function formatDate(date?: Date) {
	if (!date) return "暂无";

	return new Intl.DateTimeFormat("zh-CN", {
		timeZone: "Asia/Shanghai",
		year: "numeric",
		month: "2-digit",
		day: "2-digit",
	})
		.format(date)
		.replaceAll("/", "-");
}

function getThoughtExcerpt(body: string) {
	return body
		.replace(/!\[[^\]]*\]\([^)]*\)/g, "")
		.replace(/\[([^\]]+)\]\([^)]*\)/g, "$1")
		.replace(/[`*_>#-]/g, "")
		.replace(/\s+/g, " ")
		.trim()
		.slice(0, 92);
}
---

<MainGridLayout hideSidebar={true}>
	<div class="home-layout grid w-full grid-cols-1 gap-4 lg:grid-cols-[17.5rem_minmax(0,1fr)] lg:gap-5">
		<div class="contents lg:flex lg:flex-col lg:gap-5">
			<Profile class="home-profile order-1 w-full min-w-0 onload-animation lg:order-none" />

			<section class="home-thoughts order-3 w-full min-w-0 px-1 py-1 md:px-4 md:py-3 onload-animation lg:order-none" style="animation-delay: calc(var(--content-delay) + 100ms)">
				<div class="mb-4 flex items-center justify-between gap-3">
					<h2 class="flex items-center gap-3 text-xl font-bold text-90">
						<span class="h-6 w-1 rounded-full bg-[var(--primary)]"></span>
						<span>最新碎碎念</span>
					</h2>
					<a href={url("/thoughts/")} class="btn-plain rounded-[var(--radius-large)] px-2 py-1 text-sm font-bold text-[var(--primary)]">
						<span>更多</span>
						<Icon name="material-symbols:chevron-right-rounded" class="text-[1.1rem]" />
					</a>
				</div>
				{
					latestThoughts.length > 0 ? (
						<div class="flex flex-col gap-4">
							{latestThoughts.map((thought) => (
								<a href={url("/thoughts/")} class="group block border-b border-[var(--line-divider)] px-1 pb-4 transition last:border-b-0 hover:border-[var(--primary)] md:px-0">
									<div class="mb-2 flex items-center gap-2 text-xs font-medium text-50">
										<Icon name="material-symbols:chat-bubble-outline-rounded" class="text-[var(--primary)]" />
										<span>{formatDate(thought.data.published)}</span>
									</div>
									{thought.data.title && <div class="mb-1 font-bold leading-snug text-90 group-hover:text-[var(--primary)]">{thought.data.title}</div>}
									<p class="line-clamp-2 text-sm leading-7 text-75 md:line-clamp-3">{getThoughtExcerpt(thought.body)}</p>
								</a>
							))}
						</div>
					) : (
						<div class="px-1 py-6 text-center text-sm text-50">
							这里还没有碎碎念。
						</div>
					)
				}
			</section>
		</div>

		<div class="contents lg:flex lg:min-w-0 lg:flex-col lg:gap-5">
			<section class="home-welcome order-2 flex w-full min-w-0 flex-col gap-4 border-l-4 border-[var(--primary)] px-4 py-1 onload-animation md:py-3 lg:order-none lg:border-l-0 lg:px-4" style="animation-delay: calc(var(--content-delay) + 50ms)">
				<div>
					<h1 class="mb-3 text-[1.75rem] font-bold leading-tight text-90 md:text-3xl lg:mb-4 lg:text-[2.4rem]">
						这里是 Zellon 的小破站
					</h1>
					<p class="max-w-2xl text-sm font-medium leading-7 text-75 md:text-base lg:text-lg lg:leading-8">
						记录感兴趣的事物和折腾的过程，保留一些不够长但值得留下的日常想法。
					</p>
					<div class="home-contact mt-4 rounded-[var(--radius-large)] bg-[var(--btn-plain-bg-hover)] px-3 py-3 text-sm leading-7 text-75 lg:mt-6 lg:px-4 lg:py-4">
						<div class="font-bold text-90 lg:mb-1">联系我：</div>
						<div>Zellon0w0@163.com</div>
					</div>
				</div>
			</section>

		<section class="home-posts order-4 w-full min-w-0 onload-animation lg:order-none" style="animation-delay: calc(var(--content-delay) + 150ms)">
			<div class="mb-4 flex items-center justify-between gap-3 px-1">
				<h2 class="flex items-center gap-3 text-2xl font-bold text-90">
					<span class="h-7 w-1 rounded-full bg-[var(--primary)]"></span>
					<span>最新文章</span>
				</h2>
				<a href={url("/articles/")} class="btn-plain rounded-[var(--radius-large)] px-2 py-1 text-sm font-bold text-[var(--primary)]">
					<span>{i18n(I18nKey.more)}</span>
					<Icon name="material-symbols:chevron-right-rounded" class="text-[1.1rem]" />
				</a>
			</div>
			<PostPage page={latestPostsPage}></PostPage>
		</section>
		</div>
	</div>
</MainGridLayout>

<style>
	@media (max-width: 1023px) {
		:global(.home-profile) {
			display: flex;
			align-items: center;
			gap: 1rem;
			padding: 0.875rem;
		}

		:global(.home-profile > a) {
			flex: 0 0 5.25rem;
			width: 5.25rem;
			height: 5.25rem;
			max-width: 5.25rem;
			margin: 0;
			border-radius: 9999px;
		}

		:global(.home-profile > div) {
			min-width: 0;
			flex: 1;
			padding: 0;
		}

		:global(.home-profile > div > div:first-child) {
			margin-bottom: 0.25rem;
			text-align: left;
			font-size: 1.5rem;
			line-height: 1.2;
		}

		:global(.home-profile > div > div:nth-child(2)) {
			margin-right: auto;
			margin-bottom: 0.375rem;
			margin-left: 0;
		}

		:global(.home-profile > div > div:nth-child(3)) {
			margin-bottom: 0.75rem;
			overflow: hidden;
			text-align: left;
			text-overflow: ellipsis;
			white-space: nowrap;
			font-size: 0.875rem;
		}

		:global(.home-profile > div > div:last-child) {
			justify-content: flex-start;
			gap: 0.4rem;
			margin-bottom: 0;
		}

		:global(.home-profile .btn-regular) {
			width: 2.25rem;
			height: 2.25rem;
		}

		.home-contact {
			display: flex;
			flex-wrap: wrap;
			align-items: center;
			gap: 0.25rem 0.5rem;
		}
	}

	@media (max-width: 767px) {
		.home-posts :global(.card-base > div:first-child) {
			padding: 1rem 1rem 1rem 1.125rem;
		}

		.home-posts :global(.card-base > div:first-child > a:first-child) {
			margin-bottom: 0.75rem;
			padding-right: 1.5rem;
			font-size: 1.375rem;
			line-height: 1.45;
		}

		.home-posts :global(.card-base > div:first-child > div:nth-of-type(2)) {
			margin-bottom: 0.75rem;
			padding-right: 0;
			font-size: 0.95rem;
			line-height: 1.65;
		}
	}
</style>

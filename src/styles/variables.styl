/* utils */
white(a)
  rgba(255, 255, 255, a)

black(a)
  rgba(0, 0, 0, a)

rainbow-light = linear-gradient(to right, oklch(0.80 0.10 0), oklch(0.80 0.10 30), oklch(0.80 0.10 60), oklch(0.80 0.10 90), oklch(0.80 0.10 120), oklch(0.80 0.10 150), oklch(0.80 0.10 180), oklch(0.80 0.10 210), oklch(0.80 0.10 240), oklch(0.80 0.10 270), oklch(0.80 0.10 300), oklch(0.80 0.10 330), oklch(0.80 0.10 360))
rainbow-dark = linear-gradient(to right, oklch(0.70 0.10 0), oklch(0.70 0.10 30), oklch(0.70 0.10 60), oklch(0.70 0.10 90), oklch(0.70 0.10 120), oklch(0.70 0.10 150), oklch(0.70 0.10 180), oklch(0.70 0.10 210), oklch(0.70 0.10 240), oklch(0.70 0.10 270), oklch(0.70 0.10 300), oklch(0.70 0.10 330), oklch(0.70 0.10 360))

:root
  --radius-large 0.5rem
  --content-delay 150ms
  --pink-base: rgb(255, 182, 193)
  --pink-soft: rgb(255, 242, 245)
  --pink-strong: rgb(214, 82, 122)
  --page-gradient: linear-gradient(135deg, rgb(255, 250, 252) 0%, rgb(255, 242, 246) 42%, rgb(255, 224, 231) 100%)
  --surface-gradient: linear-gradient(135deg, rgb(255, 255, 255) 0%, rgb(255, 250, 252) 48%, rgb(255, 240, 244) 100%)
  --control-gradient: linear-gradient(135deg, rgb(255, 244, 247) 0%, rgb(255, 218, 226) 100%)
  --control-gradient-hover: linear-gradient(135deg, rgb(255, 236, 241) 0%, rgb(255, 202, 214) 100%)
  --control-gradient-active: linear-gradient(135deg, rgb(255, 224, 232) 0%, rgb(255, 190, 204) 100%)
  --accent-gradient: linear-gradient(135deg, rgb(255, 182, 193) 0%, rgb(232, 105, 147) 100%)
  --accent-gradient-strong: linear-gradient(135deg, rgb(232, 105, 147) 0%, rgb(196, 64, 112) 100%)

:root.dark
  --pink-base: rgb(255, 182, 193)
  --pink-soft: rgb(58, 34, 43)
  --pink-strong: rgb(255, 168, 192)
  --page-gradient: linear-gradient(135deg, rgb(30, 18, 24) 0%, rgb(38, 22, 30) 48%, rgb(52, 30, 39) 100%)
  --surface-gradient: linear-gradient(135deg, rgb(36, 25, 31) 0%, rgb(42, 27, 35) 52%, rgb(54, 32, 43) 100%)
  --control-gradient: linear-gradient(135deg, rgb(58, 35, 45) 0%, rgb(70, 40, 53) 100%)
  --control-gradient-hover: linear-gradient(135deg, rgb(70, 41, 54) 0%, rgb(86, 48, 64) 100%)
  --control-gradient-active: linear-gradient(135deg, rgb(86, 48, 64) 0%, rgb(104, 56, 76) 100%)
  --accent-gradient: linear-gradient(135deg, rgb(255, 182, 193) 0%, rgb(255, 137, 174) 100%)
  --accent-gradient-strong: linear-gradient(135deg, rgb(255, 154, 184) 0%, rgb(228, 96, 145) 100%)

/* An util to define variables that vary with light and dark mode */
define(vars)
  :root
    for key, value in vars
      {key}: value[0]
  :root.dark
    for key, value in vars
      if length(value) > 1
        {key}: value[1]

define({
  --primary: rgb(214, 82, 122) rgb(255, 168, 192)
  --page-bg: rgb(255, 242, 246) rgb(30, 18, 24)
  --card-bg: rgb(255, 253, 254) rgb(36, 25, 31)

  --btn-content: rgb(169, 54, 96) rgb(255, 198, 210)

  --btn-regular-bg: rgb(255, 232, 237) rgb(58, 35, 45)
  --btn-regular-bg-hover: rgb(255, 218, 226) rgb(70, 41, 54)
  --btn-regular-bg-active: rgb(255, 202, 214) rgb(86, 48, 64)

  --btn-plain-bg-hover: rgb(255, 238, 242) rgb(58, 35, 45)
  --btn-plain-bg-active: rgb(255, 224, 232) rgb(70, 41, 54)

  --btn-card-bg-hover: rgb(255, 238, 242) rgb(58, 35, 45)
  --btn-card-bg-active: rgb(255, 224, 232) rgb(70, 41, 54)

  --enter-btn-bg: var(--btn-regular-bg)
  --enter-btn-bg-hover: var(--btn-regular-bg-hover)
  --enter-btn-bg-active: var(--btn-regular-bg-active)

  --deep-text: oklch(0.25 0.02 var(--hue))

  --title-active: oklch(0.6 0.1 var(--hue))

  --line-divider: rgb(239, 188, 199) rgb(90, 54, 68)

  --line-color: rgb(229, 163, 178) rgb(118, 70, 86)
  --meta-divider: rgb(172, 105, 121) rgb(176, 115, 133)

  --inline-code-bg: var(--btn-regular-bg)
  --inline-code-color: var(--btn-content)
  --selection-bg: rgb(255, 210, 220) rgb(104, 56, 76)
  --codeblock-selection: rgb(255, 210, 220) rgb(104, 56, 76)
  --codeblock-bg: rgb(255, 247, 249) rgb(32, 22, 28)

  --license-block-bg: rgb(255, 246, 248) rgb(44, 28, 36)

  --link-underline: rgb(226, 134, 158) rgb(204, 108, 142)
  --link-hover: rgb(255, 226, 233) rgb(76, 43, 57)
  --link-active: rgb(255, 206, 218) rgb(98, 52, 72)

  --float-panel-bg: var(--card-bg)

  --scrollbar-bg-light: black(0.4)
  --scrollbar-bg-hover-light: black(0.5)
  --scrollbar-bg-active-light: black(0.6)

  --scrollbar-bg-dark: white(0.4)
  --scrollbar-bg-hover-dark: white(0.5)
  --scrollbar-bg-active-dark: white(0.6)

  --scrollbar-bg: var(--scrollbar-bg-light) var(--scrollbar-bg-dark)
  --scrollbar-bg-hover: var(--scrollbar-bg-hover-light) var(--scrollbar-bg-hover-dark)
  --scrollbar-bg-active: var(--scrollbar-bg-active-light) var(--scrollbar-bg-active-dark)

  --color-selection-bar: rainbow-light rainbow-dark

  --display-light-icon: 1 0
  --display-dark-icon: 0 1

  --admonitions-color-tip: oklch(0.7 0.14 180) oklch(0.75 0.14 180)
  --admonitions-color-note: oklch(0.7 0.14 250) oklch(0.75 0.14 250)
  --admonitions-color-important: oklch(0.7 0.14 310) oklch(0.75 0.14 310)
  --admonitions-color-warning: oklch(0.7 0.14 60) oklch(0.75 0.14 60)
  --admonitions-color-caution: oklch(0.6 0.2 25) oklch(0.65 0.2 25)

  --toc-badge-bg: rgb(255, 226, 233) var(--btn-regular-bg)
  --toc-btn-hover: rgb(255, 238, 242) rgb(58, 35, 45)
  --toc-btn-active: rgb(255, 224, 232) rgb(76, 43, 57)
  --toc-width: calc((100vw - var(--page-width)) / 2 - 1rem)
  --toc-item-active: oklch(0.70 0.13 var(--hue)) oklch(0.35 0.07 var(--hue))
})
